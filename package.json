{
  "name": "multi-pool-time-locked-staking",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "compile": "hardhat clean && hardhat compile",
    "test": "hardhat test --show-stack-traces --typecheck",
    "test:fuzz": "forge test --match-path test/foundry/FuzzDistribution.t.sol -vv",
    "test:fuzz:deep": "forge test --match-path test/foundry/FuzzDistribution.t.sol --fuzz-runs 10000 -vv",
    "coverage": "hardhat coverage",
    "deploy": "npx hardhat run ./scripts/deploy.ts --network $npm_config_network"
  },
  "devDependencies": {
    "@nomicfoundation/hardhat-toolbox": "^5.0.0",
    "@openzeppelin/contracts": "^5.0.0",
    "@types/chai": "^4.3.11",
    "@types/mocha": "^10.0.6",
    "@types/node": "^20.11.30",
    "dotenv": "^16.4.5",
    "hardhat": "^2.22.5",
    "ts-node": "^10.9.2",
    "typescript": "^5.5.4"
  }
}
